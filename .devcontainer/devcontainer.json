{
  "name": "gasolineras",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--network=host"
  ],
  "forwardPorts": [3000],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteEnv": {
    "BWS_ACCESS_TOKEN": "${localEnv:BWS_ACCESS_TOKEN}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}"
  },
  "postCreateCommand": "gh repo clone Ferezoz/dotfiles $HOME/dotfiles && $HOME/dotfiles/container/post-create.sh",
  "postStartCommand": "$HOME/dotfiles/container/post-start.sh && ./install.zsh",
  "waitFor": "postStartCommand",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "mikestead.dotenv",
        "ChFlick.firecode",
        "Anthropic.claude-code"
      ]
    }
  }
}
