{
  "name": "gasolineras",
  "private": true,
  "scripts": {
    "dev": "DOTENV_PRIVATE_KEY=${GASOLINERAS_DOTENV_PRIVATE_KEY} dotenvx run -- next dev --turbo",
    "build": "DOTENV_PRIVATE_KEY=${GASOLINERAS_DOTENV_PRIVATE_KEY} dotenvx run -- next build",
    "start": "DOTENV_PRIVATE_KEY=${GASOLINERAS_DOTENV_PRIVATE_KEY} dotenvx run -- next start",
    "lint": "DOTENV_PRIVATE_KEY=${GASOLINERAS_DOTENV_PRIVATE_KEY} dotenvx run -- next lint",
    "format": "prettier --write \"**/*.{js,ts,tsx,md,json}\"",
    "dotenvx:encrypt": "dotenvx encrypt",
    "dotenvx:decrypt": "dotenvx decrypt"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "leaflet": "^1.9.4",
    "next": "16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "@types/leaflet": "^1.9.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "vercel": "^54.13.0"
  }
}
